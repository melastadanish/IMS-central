# ─── DATABASE ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres
DIRECT_URL=postgresql://postgres:[password]@[host]:5432/postgres
# DIRECT_URL bypasses PgBouncer — required for Prisma migrations

# ─── REDIS (Upstash) ──────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# ─── AUTH ─────────────────────────────────────────────────────────────────────
JWT_SECRET=64-char-hex-string
JWT_REFRESH_SECRET=different-64-char-hex-string
# Generate: pnpm generate:jwt

# ─── ENCRYPTION ───────────────────────────────────────────────────────────────
DATABASE_ENCRYPTION_KEY=64-char-hex-string-for-aes-256
# Generate: pnpm generate:key
# WARNING: If this key is lost, ALL encrypted data is permanently unreadable.
# Back this up in a secure location BEFORE storing any production data.

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key
# WARNING: SUPABASE_SERVICE_KEY bypasses Row Level Security.
# It must NEVER appear in any frontend code or NEXT_PUBLIC_ variable.

# ─── AI ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
# Store this in Supabase Vault in production — never in .env directly

# ─── EMAIL ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-key-here
FROM_EMAIL=noreply@islamicmessagingsystem.com
REPLY_TO_EMAIL=support@islamicmessagingsystem.com

# ─── BUNNY STREAM (Video hosting) ─────────────────────────────────────────────
BUNNY_STREAM_API_KEY=
# From Bunny Dashboard > Stream > Library > API
BUNNY_STREAM_LIBRARY_ID=
# Numeric library ID from Bunny dashboard
BUNNY_STREAM_CDN_HOSTNAME=123456.b-cdn.net
BUNNY_STREAM_BASE_URL=https://video.bunnycdn.com
BUNNY_STREAM_TOKEN_KEY=
# From: Library Settings > Security > Token Authentication Key
# Store in Supabase Vault in production

# Public (safe to expose to browser — read-only)
NEXT_PUBLIC_BUNNY_STREAM_CDN_HOSTNAME=123456.b-cdn.net
NEXT_PUBLIC_BUNNY_STREAM_LIBRARY_ID=

# ─── APP ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,https://news.islamicmessagingsystem.com

# ─── PRESENTATION ─────────────────────────────────────────────────────────────
MEETING_LINK_MAX_AGE_HOURS=48

# ─── FEATURE FLAGS ────────────────────────────────────────────────────────────
ENABLE_AI_SUMMARIES=true
ENABLE_NEWS_SCRAPING=true
SCRAPE_INTERVAL_MINUTES=60
